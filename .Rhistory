nama_file_untuk_gabung <- list.files("D:/SENTIMENT ANALYSIS UGI AQIS 2026/file untuk proses gabung")
nama_file_untuk_gabung
data_artikel <- 0
for(i in 1 : length(nama_file_untuk_gabung))
{
if(i == 1)
{
nama <- paste0("D:/SENTIMENT ANALYSIS UGI AQIS 2026/file untuk proses gabung/",nama_file_untuk_gabung[i])
x <- readxl::read_xlsx(nama)
x <- as.data.frame(x)
data_artikel <- x
}
if(i > 1)
{
nama <- paste0("D:/SENTIMENT ANALYSIS UGI AQIS 2026/file untuk proses gabung/",nama_file_untuk_gabung[i])
x <- readxl::read_xlsx(nama)
x <- as.data.frame(x)
data_artikel <- rbind(data_artikel, x)
}
}
wb <- openxlsx::createWorkbook()
hs1 <- openxlsx::createStyle(fgFill = "#DCE6F1", halign = "CENTER", textDecoration = "italic",
border = "Bottom")
hs2 <- openxlsx::createStyle(fontColour = "#ffffff", fgFill = "#4F80BD",
halign = "center", valign = "center", textDecoration = "bold",
border = "TopBottomLeftRight")
openxlsx::addWorksheet(wb, "data", gridLines = TRUE)
openxlsx::writeDataTable(wb, "data", data_artikel, rowNames = FALSE, startRow = 2, startCol = 2, tableStyle = "TableStyleMedium21")
openxlsx::openXL(wb)
shiny::runApp('D:/SENTIMENT ANALYSIS UGI AQIS 2026/PROJECT SHINY DASHBOARD ANALISIS SENTIMEN 2026 TERBARU/myapp')
